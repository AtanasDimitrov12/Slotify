{
  "name": "barber-reservation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:api & pnpm run dev:web-admin",
    "dev:all": "pnpm run dev:api & pnpm run dev:web-admin & pnpm run dev:web-user",
    "dev:api": "pnpm -C apps/api/api dev",
    "dev:web-admin": "pnpm -C apps/web-admin dev",
    "dev:web-user": "pnpm -C apps/web-user dev",
    "build": "pnpm run build:api && pnpm run build:web-admin && pnpm run build:web-user",
    "build:api": "pnpm -C apps/api/api build",
    "build:web-admin": "pnpm -C apps/web-admin build",
    "build:web-user": "pnpm -C apps/web-user build",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -C apps/api/api typecheck && pnpm -C apps/web-admin typecheck && pnpm -C apps/web-user typecheck && pnpm -C packages/shared typecheck",
    "test": "pnpm -C apps/api/api test",
    "test:api:integration": "pnpm --filter api test:e2e",
    "test:web:e2e": "pnpm --filter slotify test:e2e",
    "ci:build": "pnpm run build",
    "ci:test": "pnpm run test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "mongosh": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9"
  }
}